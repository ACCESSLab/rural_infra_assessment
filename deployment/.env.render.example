# Render deployment runtime flags
PUBLIC_MODE=true
ENABLE_FULL_PIPELINE=false
ENABLE_REEVALUATION=true
ENABLE_REPORT_REGEN=false
ENABLE_FS_BROWSER=false

# Optional security token for mutating endpoints
# APP_API_TOKEN=replace-with-long-random-token

# Optional map provider token for map styles
# MAPBOX_TOKEN=pk.XXXXXXXXXXXXXXXXXXXXXXXX
